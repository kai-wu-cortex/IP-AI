{
  "entities": {
    "user": {
      "title": "User",
      "description": "A user of the application with SLA level.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier for the user (from Firebase Auth)."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "photoURL": {
          "type": "string",
          "description": "The user's profile photo URL."
        },
        "slaLevel": {
          "type": "string",
          "enum": ["free", "pro", "enterprise"],
          "description": "The Service Level Agreement (SLA) level of the user."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the user was created."
        },
        "lastLoginAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the user last logged in."
        }
      },
      "required": ["uid", "email", "slaLevel", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "user",
      "description": "Collection of user profiles."
    }
  }
}
